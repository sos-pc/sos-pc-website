<nav id="navbar">
  <div class="nav-inner">
    <a href="/" class="logo-link">
      <img src="/logo.png" alt="SOS-PC" class="logo-img" />
      <span class="logo-text mono">SOS-PC</span>
    </a>
    <ul class="nav-links" id="nav-links-list">
      <li><a href="/#about" class="nav-link">À propos</a></li>
      <li><a href="/#services" class="nav-link">Services</a></li>
      <li><a href="/#diagnostic" class="nav-link">Diagnostic</a></li>
      <li><a href="/#vitrine" class="nav-link">Portfolio</a></li>
      <li><a href="/#contact" class="nav-link">Contact</a></li>
      <li>
        <a href="/#contact" class="nav-cta mono">Devis →</a>
      </li>
    </ul>
    <div class="nav-right">
      <button class="theme-btn" id="theme-toggle" aria-label="Changer de thème">
        <span class="icon-sun">☀</span>
        <span class="icon-moon">◑</span>
      </button>
      <button class="hamburger" id="hamburger-btn" aria-label="Menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</nav>

<script>
  const hamburgerBtn = document.getElementById("hamburger-btn");
  const navLinks = document.getElementById("nav-links-list");
  const themeToggle = document.getElementById("theme-toggle");

  hamburgerBtn?.addEventListener("click", function () {
    const isOpen = navLinks!.classList.toggle("open");
    hamburgerBtn.classList.toggle("open", isOpen);
    hamburgerBtn.setAttribute("aria-expanded", isOpen ? "true" : "false");
  });

  navLinks?.querySelectorAll("a").forEach(function (link) {
    link.addEventListener("click", function () {
      navLinks!.classList.remove("open");
      hamburgerBtn!.classList.remove("open");
      hamburgerBtn!.setAttribute("aria-expanded", "false");
    });
  });

  function setTheme(isDark: boolean) {
    document.documentElement.classList.toggle("dark", isDark);
    try {
      localStorage.setItem("theme", isDark ? "dark" : "light");
    } catch {}
  }

  themeToggle?.addEventListener("click", function () {
    setTheme(!document.documentElement.classList.contains("dark"));
  });

  var savedTheme = (function () {
    try { return localStorage.getItem("theme"); } catch { return null; }
  })();
  setTheme(savedTheme !== "light");

  var navLinksEls = document.querySelectorAll(".nav-link");

  function updateActiveLink() {
    var sections = document.querySelectorAll("section[id]");
    var currentId = "";
    sections.forEach(function (section) {
      if (window.scrollY >= (section as HTMLElement).offsetTop - 100) {
        currentId = section.id;
      }
    });
    navLinksEls.forEach(function (link) {
      link.classList.toggle("active", (link as HTMLAnchorElement).getAttribute("href") === "/#" + currentId);
    });
  }

  window.addEventListener("scroll", updateActiveLink, { passive: true });
  updateActiveLink();
</script>

